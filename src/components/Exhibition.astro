<script>
  const frames = Array.from(document.querySelectorAll('.exhibition-frame'));
  const previous = document.querySelector('#previousFrame');
  const next = document.querySelector('#nextFrame');
  const currentLabel = document.querySelector('#frameNumber');
  const totalLabel = document.querySelector('#frameTotal');
  const indexToggle = document.querySelector('#indexToggle');
  const indexPanel = document.querySelector('#exhibitionIndex');
  const indexList = document.querySelector('#frameIndex');
  let current = 0;
  let locked = false;
  let wheel = 0;

  if (totalLabel) totalLabel.textContent = String(frames.length).padStart(2, '0');

  frames.forEach((frame, index) => {
    const item = document.createElement('li');
    const button = document.createElement('button');
    const route = frame.getAttribute('data-route') || '/';
    button.innerHTML = `<small>${String(index + 1).padStart(2, '0')}</small><strong>${frame.getAttribute('data-title')}</strong><span>${route}</span>`;
    button.addEventListener('click', () => { go(index); closeIndex(); });
    item.append(button);
    indexList?.append(item);
  });

  function go(target) {
    if (locked || target === current) return;
    locked = true;
    const outgoing = frames[current];
    target = (target + frames.length) % frames.length;
    const incoming = frames[target];
    outgoing?.classList.add('is-leaving');
    outgoing?.classList.remove('is-active');
    incoming?.classList.add('is-active');
    current = target;
    if (currentLabel) currentLabel.textContent = String(current + 1).padStart(2, '0');
    window.setTimeout(() => {
      outgoing?.classList.remove('is-leaving');
      locked = false;
    }, 1000);
  }

  function openIndex() {
    indexPanel?.classList.add('is-open');
    indexPanel?.setAttribute('aria-hidden', 'false');
    indexToggle?.setAttribute('aria-expanded', 'true');
  }
  function closeIndex() {
    indexPanel?.classList.remove('is-open');
    indexPanel?.setAttribute('aria-hidden', 'true');
    indexToggle?.setAttribute('aria-expanded', 'false');
  }
  function toggleIndex() { indexPanel?.classList.contains('is-open') ? closeIndex() : openIndex(); }

  previous?.addEventListener('click', () => go(current - 1));
  next?.addEventListener('click', () => go(current + 1));
  indexToggle?.addEventListener('click', toggleIndex);
  document.querySelectorAll('[data-next]').forEach((item) => item.addEventListener('click', () => go(current + 1)));

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') return closeIndex();
    if (indexPanel?.classList.contains('is-open')) return;
    if (['ArrowRight', 'ArrowDown', 'PageDown', ' '].includes(event.key)) { event.preventDefault(); go(current + 1); }
    if (['ArrowLeft', 'ArrowUp', 'PageUp'].includes(event.key)) { event.preventDefault(); go(current - 1); }
    if (event.key.toLowerCase() === 'i') toggleIndex();
  });

  document.addEventListener('wheel', (event) => {
    if (indexPanel?.classList.contains('is-open') || locked) return;
    wheel += event.deltaY + event.deltaX;
    if (Math.abs(wheel) > 120) {
      go(current + (wheel > 0 ? 1 : -1));
      wheel = 0;
    }
  }, { passive: true });

  let touchStart = null;
  document.addEventListener('touchstart', (event) => { touchStart = event.changedTouches[0]?.clientX ?? null; }, { passive: true });
  document.addEventListener('touchend', (event) => {
    if (touchStart === null) return;
    const end = event.changedTouches[0]?.clientX ?? touchStart;
    const delta = end - touchStart;
    if (Math.abs(delta) > 50) go(current + (delta < 0 ? 1 : -1));
    touchStart = null;
  }, { passive: true });
</script>
