---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';

interface Props {
  title?: string;
  description?: string;
  exhibition?: boolean;
}

const {
  title = 'Nodens',
  description = 'A curated self-portrait in systems, texts, rituals, objects, and ongoing work.',
  exhibition = false,
} = Astro.props;
const pageTitle = title === 'Nodens' ? title : `${title} · Nodens`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ece7dc" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{pageTitle}</title>
  </head>
  <body class:list={{ 'is-exhibition': exhibition }}>
    <a class="skip-link" href="#main">Skip to content</a>
    <SiteHeader exhibition={exhibition} />
    <slot />
    <slot name="footer" />
  </body>
</html>
